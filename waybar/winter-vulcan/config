{
    "layer": "top",
    "position": "top", 
    "height": 30,
    "margin": "0 0 0 0",
    //"spacing": 4, // –†–∞–Ј–Љ–µ—А –њ—А–Њ–Љ–µ–ґ—Г—В–Ї–Њ–≤ –Љ–µ–ґ–і—Г —А–∞–Ј–ї–Є—З–љ—Л–Љ–Є –Љ–Њ–і—Г–ї—П–Љ–Є
    //Modules
    "modules-left": ["hyprland/workspaces","custom/separator","mpris"],
    "modules-center": ["clock",],
    "modules-right": ["tray","pulseaudio","temperature","cpu","bluetooth","network","custom/power"],
    // Modules configuration
    

    //left
    "custom/launcher": {
        "format":"   вЛП",
        "on-click": "exec wofi --show drun -o",
        "tooltip": false,
        //"exec": "~/.config/hypr/scripts/tools/expand wall",
        // "interval": 1,
        "on-click-right": "~/.config/hypr/scripts/tools/expand cycle"
    },
    "hyprland/workspaces": {
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "format": "{icon}",
    "format-icons": {
      "1": "дЄА",
      "2": "дЇМ",
      "3": "дЄЙ",
      "4": "еЫЫ",
      "5": "дЇФ",
      "6": "еЕ≠",
      "7": "дЄГ",
      "8": "еЕЂ",
      "9": "дєЭ",
      "10":"еНБ",
      "urgent": "пБ™",
      }
    },

    "custom/separator": {
        "format": " ",
        "interval": "once",
        "tooltip": false
    },
     "mpris":{
        //"format":"{player} ({status}) {dynamic}",
        "format": "пЖЉ {dynamic}",
        "dynamic-order": ["title", "artist"],
        "dynamic-len": 35
	  },






    
    
    

    //center
    "clock": {
        "tooltip-format": "{:%A %B %d %Y | %H:%M}",
        "format": "пД≥  {:%a %d %b пАЧ %I:%M %p}",	//12 hour format 
        //"format": "пД≥ {:%a %d %b пАЧ %H:%M}",	//24 hour format 
        "format-alt": "пД≥  {:%d/%m/%Y пАЧ %H:%M:%S}",
        "interval": 1,
        "on-click-right": "exec python ~/.config/hypr/scripts/wall_top.py"
    },





    //right
    "pulseaudio": {
      "on-click-middle": "pavucontrol",
      "on-click-right": "exec wpctl set-mute @DEFAULT_SOURCE@ toggle",
      "on-click": "exec wpctl set-mute @DEFAULT_SINK@ toggle",
      // "scroll-step": 1, // %, can be a float
      "format": "{icon} {volume}% {format_source}",
      "format-bluetooth": "{icon}пКФ {volume}% {format_source}",
      "format-bluetooth-muted": "пС¶ {format_source}",
      "format-muted": "пС¶  {format_source}",
      "format-source": "пД∞ {volume}%",
      "format-source-muted": "пД±",
      "format-icons": {
        "headphone": "пА•",
        "hands-free": "пЦР",
        "headset": "рЯОІ",
        "phone": "пВХ",
        "portable": "пВХ",
        "car": "пЖє",
        "default": ["пА¶", "пАІ", "пА®"]
      }
    },
    "cpu": {
        "format": "{usage}% пЛЫ",
        "on-click": "footclient -H  htop"
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        //"format-critical": "{temperatureC}¬∞C {i"custom/ss"con}",
        "format": "{temperatureC}¬∞C {icon}",
        "format-icons": ["пЭЂ", "пЛЙ", "пЭ©"],
        "on-click": "footclient -H  htop"
    },
    "bluetooth":{
        "on-click":"blueman-manager",
        "format": "пКФ {status}",
    },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    },
    "network": {
        "format": "{icon}",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
        "format-wifi": "{icon} {essid}",
        "format-icons": {
            "wifi": ["п™©", "п™®" ,"пЗЂ"],
            "ethernet": ["пЫњ "],
            "disconnected": ["вЪ† Disabled"]
        },
        "on-click": "footclient systemctl status NetworkManager",
        "tooltip-format": "{ifname}: {ipaddr}",
    },
    "custom/power": {
        "format":"гВ™гГХ",
        "on-click": "sh $HOME/.config/rofi/winter-vulcan/bin/powermenu",
        "on-click-right": "systemctl soft-reboot",
        "tooltip": false,
    },

}
